{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/dms/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "core/swagger/**/*",
        "watchAssets": true
      }
    ],
    "webpack": true,
    "tsConfigPath": "apps/dms/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/dms",
  "projects": {
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json",
        "assets": [
          {
            "include": "swagger/**/*",
            "watchAssets": true
          }
        ]
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "dms": {
      "type": "application",
      "root": "apps/dms",
      "entryFile": "main",
      "sourceRoot": "apps/dms/src",
      "compilerOptions": {
        "tsConfigPath": "apps/dms/tsconfig.app.json"
      }
    }
  }
}