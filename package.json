{
  "name": "dms",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/dms/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:secret": "secretlint \"**/*\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/dms/apps/service/dms/test/jest-e2e.json",
    "husky:prepare": "husky",
    "seed": "ts-node -r tsconfig-paths/register src/seeder/seed.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.1.0",
    "@google/genai": "^1.34.0",
    "@keyv/redis": "^5.1.6",
